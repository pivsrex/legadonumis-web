---
import Layout from '../layouts/Layout.astro'
import { es as content } from '../content/es'
import Navbar      from '../components/Navbar'
import Hero        from '../components/Hero'
import Workflow    from '../components/Workflow'
import Showcase    from '../components/Showcase'
import Features    from '../components/Features'
import Comparison  from '../components/Comparison'
import Testimonials from '../components/Testimonials'
import FAQ         from '../components/FAQ'
import Newsletter  from '../components/Newsletter'
import FinalCTA    from '../components/FinalCTA'
import Footer      from '../components/Footer'
---
<Layout
  lang="es"
  title="Legado — El museo digital de tu colección"
  description="Software de escritorio para organizar, documentar y analizar tu colección de monedas. Descarga gratuita. Mac y Windows."
  canonical="https://legadonumis.com/"
  ogTitle="Legado — El museo digital de tu colección"
  ogImage="https://legadonumis.com/assets/og-image.png"
>
  <Navbar content={content} lang="es" altUrl="/en/" client:load />
  <main>
    <Hero        content={content} />
    <Workflow    content={content} />
    <Showcase    content={content} client:visible />
    <Features    content={content} />
    <Comparison  content={content} client:visible />
    <Testimonials content={content} />
    <FAQ         content={content} client:visible />
    <Newsletter  lang="es" client:visible />
    <FinalCTA    content={content} />
  </main>
  <Footer content={content} />
</Layout>
