---
export interface Props {
  lang: 'es' | 'en'
  title: string
  description: string
  canonical: string
  ogTitle: string
  ogImage: string
}

const { lang, title, description, canonical, ogTitle, ogImage } = Astro.props
const altLang   = lang === 'es' ? 'en' : 'es'
const altCanon  = lang === 'es' ? 'https://legadonumis.com/en/' : 'https://legadonumis.com/'
const ogLocale  = lang === 'es' ? 'es_ES' : 'en_US'
const schemaLang = lang
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <title>{title}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang={lang}    href={canonical} />
  <link rel="alternate" hreflang={altLang} href={altCanon} />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={ogTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:locale"      content={ogLocale} />
  <meta property="og:site_name"   content="Legado" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={ogTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/inter-latin-600-normal.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Cloudflare Web Analytics (sin cookies) -->
  <script is:inline type="module" src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "51d0715c27da43b2b8eadeb0817334c3"}'></script>

  <link rel="icon" type="image/svg+xml" href="/assets/LogoSoloClaroTrans.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
  <link rel="stylesheet" href="/styles/tokens.css" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Legado",
    "description": description,
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": ["macOS", "Windows"],
    "inLanguage": schemaLang,
    "url": "https://legadonumis.com",
    "offers": [
      { "@type": "Offer", "name": "Legado Basic", "price": "0", "priceCurrency": "EUR" },
      { "@type": "Offer", "name": "Legado Pro",   "price": "89", "priceCurrency": "EUR" }
    ]
  })} />

  <script is:inline>
    document.documentElement.classList.add('js');
    (function(){var u=navigator.userAgent;if(/Win/.test(u))document.documentElement.classList.add('is-win');else if(/Mac|Macintosh/.test(u))document.documentElement.classList.add('is-mac');})();
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: var(--ds-bg-0); color: var(--ds-text-high); margin: 0; }
    a { color: inherit; text-decoration: none; }
    button { cursor: pointer; }
    html { scroll-behavior: smooth; }

    ::-webkit-scrollbar { width: 12px; }
    ::-webkit-scrollbar-track { background: var(--ds-bg-0); }
    ::-webkit-scrollbar-thumb { background: var(--ds-bg-3); border-radius: 6px; border: 3px solid var(--ds-bg-0); }

    /* Scroll reveal — solo se oculta si hay JS (html.js), así el contenido
       es visible sin JavaScript y para crawlers que no lo ejecutan */
    html.js [data-reveal] {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.5s ease var(--reveal-delay, 0ms),
        transform 0.5s cubic-bezier(0.4,0,0.2,1) var(--reveal-delay, 0ms);
    }
    html.js [data-reveal].is-revealed { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      html.js [data-reveal] { opacity: 1; transform: none; transition: none; }
    }

    /* Lupa interactiva sobre la moneda (CTA final) */
    .lg-coin-loupe { touch-action: pan-y; }
    .lg-coin-lens {
      position: absolute; top: 0; left: 0;
      width: 132px; height: 132px; border-radius: 50%;
      border: 1px solid rgba(201, 168, 76, 0.55);
      box-shadow: 0 10px 34px rgba(0,0,0,0.65), inset 0 0 14px rgba(0,0,0,0.4);
      background-repeat: no-repeat;
      pointer-events: none;
      opacity: 0;
      transition: opacity 180ms ease;
      transform: translate(-50%, -50%);
    }
    .lg-coin-loupe.is-active .lg-coin-lens { opacity: 1; }
    .lg-coin-hint { transition: opacity 500ms ease; }
    .lg-coin-hint.is-hidden { opacity: 0; }

    /* Menú desplegable de descarga (Básico/Pro) */
    .lg-dl-menu {
      position: absolute; top: calc(100% + 8px); right: 0; min-width: 240px;
      background: #181818;
      border: 1px solid rgba(201, 168, 76, 0.35);
      border-radius: 12px;
      box-shadow: 0 18px 48px rgba(0, 0, 0, 0.6);
      padding: 6px;
      z-index: 300;
      opacity: 0;
      transform: translateY(-6px);
      pointer-events: none;
      transition: opacity 160ms ease, transform 160ms ease;
    }
    .lg-dl.open .lg-dl-menu { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .lg-dl-menu.center { left: 50%; right: auto; transform: translate(-50%, -6px); }
    .lg-dl.open .lg-dl-menu.center { transform: translate(-50%, 0); }
    .lg-dl-item {
      display: flex; flex-direction: column; gap: 3px;
      padding: 12px 14px; border-radius: 8px; text-decoration: none;
      text-align: left;
    }
    .lg-dl-item:hover { background: rgba(255, 255, 255, 0.05); }
    .lg-dl-item strong { font: 600 14px/1.2 var(--font-display); color: var(--ds-text-high); letter-spacing: -0.01em; }
    .lg-dl-item.pro strong { color: var(--ds-accent); }
    .lg-dl-item span { font: 400 12px/1.3 var(--font-body); color: var(--ds-text-mid); }
    .lg-dl-caret { flex-shrink: 0; transition: transform 160ms ease; }
    .lg-dl.open .lg-dl-caret { transform: rotate(180deg); }

    /* Destello al pasar el ratón por los botones de descarga */
    .lg-btn-shine { position: relative; overflow: hidden; }
    .lg-btn-shine::after {
      content: '';
      position: absolute; inset: 0; border-radius: inherit;
      background: linear-gradient(115deg, transparent 35%, rgba(255,255,255,0.45) 50%, transparent 65%) no-repeat;
      background-size: 250% 100%;
      background-position: 180% 0;
      pointer-events: none;
    }
    .lg-btn-shine:hover::after { animation: lgBtnShine 1.3s ease; }
    @keyframes lgBtnShine { to { background-position: -80% 0; } }
    @media (prefers-reduced-motion: reduce) {
      .lg-btn-shine:hover::after { animation: none; }
    }

    @media (max-width: 1024px) {
      .lg-feature-grid   { grid-template-columns: repeat(2, 1fr) !important; }
      .lg-workflow-track { grid-template-columns: repeat(2, 1fr) !important; }
      .lg-footer-grid    { grid-template-columns: 1fr 1fr 1fr !important; gap: 32px !important; }
    }
    @media (max-width: 768px) {
      .lg-nav-links      { display: none !important; }
      .lg-nav-btns       { display: none !important; }
      .lg-section-head   { grid-template-columns: 1fr !important; gap: 12px !important; }
      .lg-feature-grid   { grid-template-columns: 1fr !important; }
      .lg-workflow-track { grid-template-columns: 1fr !important; }
      .lg-showcase-section { min-height: auto !important; margin-top: 24px !important; }
      .lg-showcase-sticky  { position: relative !important; top: auto !important; padding: 0 16px !important; }
      .lg-showcase-card    { height: auto !important; grid-template-columns: 1fr !important; }
      .lg-showcase-media   { height: 220px !important; }
      .lg-showcase-header  { padding-top: 80px !important; }
      .lg-footer-grid    { grid-template-columns: 1fr 1fr !important; gap: 24px !important; }
      section { padding-top: 80px !important; }
      #showcase { padding-top: 0 !important; }
    }
    @media (max-width: 480px) {
      .lg-footer-grid { grid-template-columns: 1fr !important; }
      .lg-showcase-header { padding-top: 64px !important; }
      section { padding-top: 64px !important; }
      #showcase { padding-top: 0 !important; }
    }
  </style>
</head>
<body>
  <slot />
  <script>
    // Scroll reveal via vanilla JS (no React hydration needed)
    (function () {
      const seen = new WeakSet()
      const obs = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('is-revealed'); obs.unobserve(e.target) }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -32px 0px' }
      )
      const watch = (el) => { if (!seen.has(el)) { seen.add(el); obs.observe(el) } }
      const scan = (root) => {
        if (root.nodeType !== 1 && root.nodeType !== 9) return
        if (root.nodeType === 1 && root.hasAttribute('data-reveal')) watch(root)
        root.querySelectorAll('[data-reveal]').forEach(watch)
      }
      scan(document)
      // Las islas de Astro pueden recrear su DOM al hidratar (descartando los nodos
      // SSR ya observados). Re-escaneamos cualquier nodo nuevo para no perder reveals.
      new MutationObserver((muts) =>
        muts.forEach(m => m.addedNodes.forEach(n => scan(n)))
      ).observe(document.body, { childList: true, subtree: true })
    })()

    // Menú desplegable de descarga (Básico/Pro).
    // Delegación en document: sobrevive a la hidratación de las islas.
    ;(function () {
      const isMac = /Mac/.test(navigator.userAgent)
      const cerrar = () => document.querySelectorAll('.lg-dl.open').forEach((d) => {
        d.classList.remove('open')
        const t = d.querySelector('[data-dl-toggle]')
        if (t) t.setAttribute('aria-expanded', 'false')
      })

      document.addEventListener('click', (e) => {
        const t = e.target
        if (!(t instanceof Element)) return

        const toggle = t.closest('[data-dl-toggle]')
        if (toggle) {
          e.preventDefault()
          const wrap = toggle.closest('.lg-dl')
          if (!wrap) return
          const abierto = wrap.classList.contains('open')
          cerrar()
          if (!abierto) {
            wrap.classList.add('open')
            toggle.setAttribute('aria-expanded', 'true')
          }
          return
        }

        const basic = t.closest('a[data-mac]')
        if (basic) {
          e.preventDefault()
          const url = basic.getAttribute(isMac ? 'data-mac' : 'data-win')
          if (url) window.location.href = url
          return
        }

        cerrar()
      })

      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') cerrar() })
    })()

    // Vídeos marcados como solo-escritorio: cargarlos únicamente en pantallas grandes
    ;(function () {
      if (!window.matchMedia('(min-width: 769px)').matches) return
      document.querySelectorAll('video[data-desktop-src]').forEach((v) => {
        if (!(v instanceof HTMLVideoElement)) return
        v.src = v.getAttribute('data-desktop-src') || ''
        v.autoplay = true
        v.play().catch(() => {})
      })
    })()

    // Resplandor de borde que sigue al cursor (features y FAQ).
    // Delegación en document: sobrevive a que las islas recreen su DOM al hidratar.
    ;(function () {
      document.addEventListener('pointermove', (e) => {
        const t = e.target
        if (!t || !(t instanceof Element)) return
        const card = t.closest('.lg-feature-card, .lg-faq-card')
        if (!card) return
        const r = card.getBoundingClientRect()
        card.style.setProperty('--mx', (e.clientX - r.left) + 'px')
        card.style.setProperty('--my', (e.clientY - r.top) + 'px')
      }, { passive: true })
    })()
  </script>
</body>
</html>
